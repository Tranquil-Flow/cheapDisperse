# cheapDisperse Hardhat — TESTNET deployment environment variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is listed in .gitignore.

# ------------------------------------------------------------
# Deployer private key (with 0x prefix)
# Used for all network deployments in hardhat.config.ts
# Default fallback is Hardhat account #0 (for local only)
# ------------------------------------------------------------
DEPLOYER_PRIVATE_KEY=<REPLACE_WITH_DEPLOYER_PRIVATE_KEY>

# ------------------------------------------------------------
# Alchemy API key — used to build RPC URLs for testnet networks
# Provides access to: Sepolia, Base Sepolia, etc.
# Get one at: https://dashboard.alchemy.com
# ------------------------------------------------------------
ALCHEMY_API_KEY=<REPLACE_WITH_ALCHEMY_API_KEY>

# ------------------------------------------------------------
# Etherscan API key for contract verification
# Used in hardhat.config.ts verify.etherscan.apiKey
# Get one at: https://etherscan.io/myapikey
# ------------------------------------------------------------
ETHERSCAN_API_KEY=<REPLACE_WITH_ETHERSCAN_API_KEY>
